@if (IsVisible)
{
    <div class="modal-backdrop app-modal-backdrop">
        <div class="modal-dialog app-modal-dialog">
            <div class="modal-content app-modal-content @(isError ? "danger" : "")">
                <div class="modal-header">
                    <h4 class="modal-title">@Title</h4>
                </div>
                <div class="modal-body">
                    @Message
                </div>
                <div class="modal-footer app-modal-footer">
                    @if (isError)
                    {
                        <button class="btn-dialog btn-error" @onclick="OnCancelClicked">Dismiss</button>
                    }
                    else
                    {
                        <button class="btn-dialog btn-secondary" @onclick="OnCancelClicked">Cancel</button>
                        <button class="btn-dialog btn-confirm" @onclick="OnConfirmClicked">Confirm</button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string? Title { get; set; }
    [Parameter] public string Message { get; set; } = string.Empty;
    [Parameter] public EventCallback<bool> OnClose { get; set; }

    private bool IsVisible { get; set; }
    private bool isError { get; set; }

    public void Show(string message, string? title = null)
    {
        isError = false;
        Message = message;
        Title = title ?? Resources.messaging_service_title_confirm;
        IsVisible = true;
        StateHasChanged();
    }

    public void ShowError(string message, string? title = null)
    {
        isError = true;
        Message = message;
        Title = title ?? Resources.messaging_service_title_error;
        IsVisible = true;
        StateHasChanged();
    }

    private async Task OnConfirmClicked()
    {
        IsVisible = false;
        await OnClose.InvokeAsync(true);
    }

    private async Task OnCancelClicked()
    {
        IsVisible = false;
        await OnClose.InvokeAsync(false);
    }
}