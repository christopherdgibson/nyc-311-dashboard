@code {
    [Parameter] public string? Text { get; set; }
    [Parameter] public int MaxLength { get; set; } = 100;

    private bool expanded = false;

    private string? DisplayText => expanded ? Text : Text?.Substring(0, MaxLength) + "...";
}

<button class="expand-cell-btn" @onclick="() => expanded = !expanded">
    <div style="flex: 1;">
        @DisplayText
    </div>
    <i class="bi @(expanded ? "bi-chevron-up" : "bi-chevron-down") menu-icon-btn"></i>
</button>