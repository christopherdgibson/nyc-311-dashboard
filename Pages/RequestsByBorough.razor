@inject IRequestService RequestService
@inject IChartService ChartService
@inject ILayoutService LayoutService

@page "/requestsbyborough"

@using CSharpFunctionalExtensions
@using NYC311Dashboard.Components
@using NYC311Dashboard.Constants
@using NYC311Dashboard.Extensions
@using NYC311Dashboard.Models
@using NYC311Dashboard.Services
@using NYC311Dashboard.Services.Contracts
@using System.Text.Json
@using NYC311Dashboard.Services.Models

<PageTitle>@Resources.title_borough</PageTitle>

@if (ShowChart)
{
    <div class="content-block">
        <h2>@Resources.title_borough_requests_chart</h2>
        <div class="apex-chart-container chart-single-flex-container pageview-block">
            <div id="@SharedJsConstants.BoroughChartId" class="chart-flex-item"></div>
        </div>
        <hr class="section-divider" />
        <h2>@Resources.title_borough_requests_table</h2>
        <div class="table-flex-container pageview-block">
            <SortableTable Items="requestsByBorough" Options=@GetTableOptions() />
        </div>
    </div>
}

@code {
    private List<BoroughDateTableRow>? requestsByBorough = new List<BoroughDateTableRow>();
    private HashSet<string>? selectedBoroughs = new();

    private bool chartNeedsRefresh = false;
    private bool ShowChart => requestsByBorough?.Count > 0 && selectedBoroughs?.Count > 0;

    //private DotNetObjectReference<RequestsByBorough>? dotNetRef;

    protected override void OnInitialized()
    {
        LayoutService.SetTitle(Resources.title_borough, Resources.title_requests_by);
    }

    protected override async Task OnInitializedAsync()
    {
        await Task.CompletedTask; // suppress warning to leave async if needed

        if (RequestService.Boroughs.Count == 0)
        {
            LayoutService.SetSidebar(
                LayoutService.RenderInactiveButton(Resources.data_none_available, Resources.refresh_data_boroughs_list)
        );
            return;
        }

        if (!(RequestService.RequestsByBoroughDate?.Count > 0))
        {
            RefreshRequestsByBorough();
        }
        else
        {
            requestsByBorough = new List<BoroughDateTableRow>(RequestService.RequestsByBoroughDate);
        }

        selectedBoroughs = RequestService.SelectedBoroughs;

        var configs =
            new CheckboxDropdownConfig<string>(
            Label: Resources.title_borough,
            Options: RequestService.Boroughs,
            SelectedValues: selectedBoroughs,
            SelectedValuesChanged: EventCallback.Factory.Create<HashSet<string>>(this, v => selectedBoroughs = v),
            OnSelectionChanged: OnBoroughSelectionChanged)
        ;

        LayoutService.SetSidebar(LayoutService.RenderCheckboxDropdown(configs, Resources.label_select_boroughs));

        chartNeedsRefresh = ShowChart;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!chartNeedsRefresh)
        {
            return;
        }

        chartNeedsRefresh = false;
        await ChartService.RenderBarChart($"#{SharedJsConstants.BoroughChartId}");

        // if (firstRender)
        // {
        //     await ChartService.RenderBarChart(SharedJsConstants.ChartId, chartOptions);
        //     dotNetRef = DotNetObjectReference.Create(this);
        //     await JS.InvokeVoidAsync("notifyChartDivReady", dotNetRef);
        //     await ChartService.UpdateApexChart(chartOptions);
        // }
    }

    // [JSInvokable]
    // public async Task RenderChartFromJS()
    // {
    //     await ChartService.RenderBarChart(chartOptions);
    // }

    private Task OnBoroughSelectionChanged()
    {
        RefreshRequestsByBorough();
        chartNeedsRefresh = ShowChart;
        return Task.CompletedTask;
    }

    protected void RefreshRequestsByBorough()
    {
        var result = RequestService.GenerateTableByBoroughDay();
        if (result.IsFailure)
        {
            return;
        }

        requestsByBorough = new List<BoroughDateTableRow>(RequestService.RequestsByBoroughDate);
    }

    private TableOptions<BoroughDateTableRow> GetTableOptions() => RequestService.GetTableOptions<BoroughDateTableRow>(r => r.Borough);
}
