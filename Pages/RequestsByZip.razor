@inject IRequestService RequestService
@inject IChartService ChartService
@inject ILayoutService LayoutService

@page "/requestsbyzip"

@using CSharpFunctionalExtensions
@using NYC311Dashboard.Components
@using NYC311Dashboard.Constants
@using NYC311Dashboard.Models
@using NYC311Dashboard.Services
@using NYC311Dashboard.Services.Contracts
@using NYC311Dashboard.Extensions
@using NYC311Dashboard.Services.Models

<PageTitle>@Resources.title_zip_code</PageTitle>

@if (ShowChart)
{
    <div class="content-block">
        <h2>@Resources.title_zip_requests_chart</h2>
        <div id="@SharedJsConstants.ZipChartId" class="apex-chart-flex-container"></div>
        <hr class="section-divider" />
        <h2>@Resources.title_zip_requests_table</h2>
        <div class="table-flex-container">
            <SortableTable Items="requestsByZipHour" Options=@GetTableOptions() />
        </div>
    </div>
}

@code {
    private List<ZipHourTableRow>? requestsByZipHour = new List<ZipHourTableRow>();
    private HashSet<string>? selectedZipCodes = new();

    private bool chartNeedsRefresh = false;
    private bool ShowChart => requestsByZipHour?.Count > 0 && selectedZipCodes?.Count > 0;

    protected override void OnInitialized()
    {
        LayoutService.SetTitle(Resources.title_zip_code, Resources.title_requests_by);
    }

    protected override async Task OnInitializedAsync()
    {
        await Task.CompletedTask; // suppress warning to leave async if needed

        if (!(RequestService.Boroughs?.Count > 0))
        {
            LayoutService.SetSidebar(
                LayoutService.RenderInactiveButton(Resources.data_none_available, Resources.refresh_data_boroughs_list));

            return;
        }

        if (!(RequestService.SelectedBoroughs?.Count > 0)) // selected boroughs check necessary for checkbox null error. Always the case?
        {
            LayoutService.SetSidebar(
                LayoutService.RenderInactiveButton(Resources.data_none_available, 
                    string.Join(" ", string.Format(Resources.empty_selction, Resources.groupby_category_boroughs), string.Format(Resources.select_boroughs_for_data, Resources.groupby_category_zip_codes))));

            return;
        }

        RefreshRequestsByZipHour();

        // if (RequestService.RequestsByZipHour.Count == 0) // would need to also condition on borough selection changed to keep this but maybe not worth it
        // {
        //     await RefreshRequestsByZipHour();
        // }
        // else
        // {
        //     requestsByZipHour = RequestService.RequestsByZipHour;
        // }

        selectedZipCodes = RequestService.SelectedZipCodes;

        var configs = RequestService.BoroughZipSelections.Select(b =>
        new CheckboxDropdownConfig<string>(
            Label: b.Borough,
            Options: b.AvailableZips,
            SelectedValues: b.SelectedZips,
            SelectedValuesChanged: EventCallback.Factory.Create<HashSet<string>>(this,
                v => b.SelectedZips = v),
            OnSelectionChanged: OnZipSelectionChanged
        ));

        LayoutService.SetSidebar(LayoutService.RenderMultipleCheckboxDropdowns(configs, Resources.label_select_zip_codes));

        chartNeedsRefresh = ShowChart;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!chartNeedsRefresh)
        {
            return;
        }

        chartNeedsRefresh = false;
        await ChartService.RenderLineChart($"#{SharedJsConstants.ZipChartId}");
    }

    private Task OnZipSelectionChanged()
    {
        RefreshRequestsByZipHour();
        chartNeedsRefresh = ShowChart;
        return Task.CompletedTask;
    }

    protected void RefreshRequestsByZipHour()
    {
        var result = RequestService.GenerateTableByZipHour();
        if (result.IsFailure)
        {
            return;
        }

        requestsByZipHour = new List<ZipHourTableRow>(RequestService.RequestsByZipHour); // snapshot that keeps old data if failure
    }

    private TableOptions<ZipHourTableRow> GetTableOptions() => RequestService.GetTableOptions<ZipHourTableRow>(r => r.Borough);
}